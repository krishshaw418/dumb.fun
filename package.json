{
  "name": "pumpfun-clone",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:indexer": "yarn workspace indexer ts-node-dev src/index.ts",
    "dev:api": "yarn workspace api ts-node-dev src/index.ts",
    "dev:web": "yarn workspace web dev",
    "build": "yarn workspaces run build",
    "db:generate": "yarn workspace db db:generate",
    "db:migrate": "yarn workspace db db:migrate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3"
  },
  "packageManager": "yarn@4.13.0"
}
